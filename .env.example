# ====================================================================
# AUTO-TELEFLOW BOT CONFIGURATION (.env)
# Rename this file to .env and fill in the values below
# ====================================================================

# Telethon API Credentials (Get these from https://my.telegram.org)
API_ID=your_api_id_here
API_HASH=your_api_hash_here

# Database Configuration (Shared SQLite database path)
DATABASE_PATH=data/bot.db

# Master / Administrator Telegram Authorization
# You can fill in the username (without @) OR the numeric user ID, or both.
MASTER_USERNAME=your_telegram_username
MASTER_ID=your_numeric_telegram_user_id

# Web Panel Authentication (Unified credentials)
# Set a custom password and secure cookie session secret
WEB_ADMIN_USERNAME=admin
WEB_ADMIN_PASSWORD=change_this_to_a_strong_password
WEB_SESSION_SECRET=generate_a_long_random_string_here

# System Log Level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Session File Configuration (Path to the session file)
SESSION_NAME=sessions/promo_userbot

# Reporting and Backup Settings
# Targets can be chat IDs (numeric) or 'me'
REPORT_TARGET=me
BACKUP_TARGET=me
BACKUP_PASSWORD=your_secure_backup_password
SEND_REPORT=true
RUN_WAVE_ON_START=false

# Auto-Scheduling Wave Settings (Delays in minutes)
DEFAULT_MIN_DELAY_MINUTES=60
DEFAULT_MAX_DELAY_MINUTES=180
DELAY_BETWEEN_GROUPS_SECONDS=15

# Backup Security Settings
ALLOW_UNENCRYPTED_BACKUP=true
BACKUP_INCLUDE_ENV=false
DELETE_LOCAL_BACKUP_AFTER_SEND=true

# FastAPI Web Control Panel Settings
ENABLE_WEB_PANEL=true
WEB_HOST=0.0.0.0
WEB_PORT=4765
WEB_TRUST_PROXY=false
