# Assistant specific secrets and databases
assistant/.env
assistant/data/*.db
assistant/data/*.db-journal
assistant/data/*.db-wal
assistant/data/*.db-shm
assistant/backups/*

# General Telethon / SQLite files (backup protection)
*.session
*.session-journal
sessions/*.session
sessions/*.session-journal
data/*.db
data/*.db-journal
*.db
*.db-journal

# Compiled Python files
__pycache__/
**pycache**/
*.pyc
*.pyo
*.pyd
*.py[cod]
*$py.class

# Local backups and logs
backups/*
*.log
logs/

# IDE settings
.vscode/
.idea/
*.suo
*.swp

# Model agent folders
.agents/
production_artifacts/
