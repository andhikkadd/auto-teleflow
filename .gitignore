# Environments and Secrets
.env
.venv
venv/
ENV/
env/

# Campaigns specific secrets and databases
campaigns/.env
campaigns/*.session
campaigns/*.session-journal
campaigns/sessions/*.session
campaigns/sessions/*.session-journal
campaigns/data/*.db
campaigns/data/*.db-journal
campaigns/data/*.db-wal
campaigns/data/*.db-shm
